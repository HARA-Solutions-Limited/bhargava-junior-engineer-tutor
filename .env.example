# Elastic Cloud (Observability + Agent Builder)
KIBANA_URL=https://YOUR-DEPLOYMENT.kb.REGION.cloud.es.io
ELASTICSEARCH_URL=https://YOUR-DEPLOYMENT.es.REGION.cloud.es.io
# Agent Builder API key — full encoded value from Kibana (id:secret base64, no spaces)
API_KEY=

# Optional: Elasticsearch API key for Elastic Observability MCP app (stretch)
ELASTICSEARCH_API_KEY=

# OTLP — copy from Elastic Cloud → Add data → OpenTelemetry → Managed OTLP Endpoint
# Format: https://my-cluster.ingest.REGION.cloud.elastic.cloud:443 (must resolve via DNS)
# Synced to vendor/.env.override by ./scripts/sync-elastic-config.sh
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS="Authorization=ApiKey YOUR_OTLP_ENCODED_KEY"

# Injected into agent instructions by create-agent.sh
KIBANA_BASE_URL=${KIBANA_URL}

# Astronomy Shop
SHOP_URL=http://localhost:8080
