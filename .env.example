# Elastic Cloud (Observability + Agent Builder)
KIBANA_URL=https://YOUR-DEPLOYMENT.kb.REGION.cloud.es.io
ELASTICSEARCH_URL=https://YOUR-DEPLOYMENT.es.REGION.cloud.es.io
API_KEY=

# OTLP export for Astronomy Shop (see docs/elastic-cloud-setup.md)
# Also copy these into vendor/elastic-opentelemetry-demo/.env.override as:
#   ELASTIC_OTLP_ENDPOINT="<endpoint>"
#   ELASTIC_OTLP_API_KEY="<api-key>"
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Injected into agent instructions by create-agent.sh
KIBANA_BASE_URL=${KIBANA_URL}

# Astronomy Shop
SHOP_URL=http://localhost:8080
